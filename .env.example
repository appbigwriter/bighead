# Ambiente de execução da aplicação; defina no painel da hospedagem como development, test, staging ou production.
APP_ENV=development
# URL pública canônica do frontend; obtenha após criar o domínio/deploy no provedor de hospedagem web.
APP_URL=http://localhost:3000
# URL pública da API FastAPI; obtenha após publicar a API no provedor de containers/PaaS.
API_URL=http://localhost:8000
# Origens autorizadas pelo CORS, separadas por vírgula; use os domínios públicos do frontend fornecidos pela hospedagem.
CORS_ORIGINS=http://localhost:3000
# Nível mínimo dos logs da aplicação; escolha entre DEBUG, INFO, WARNING ou ERROR conforme o ambiente.
LOG_LEVEL=INFO
# Host pÃºblico do frontend usado pelo Caddy na VPS; crie registros DNS A/AAAA apontando para a VPS.
WEB_DOMAIN=head.fbr.news
# Host pÃºblico da API usado pelo Caddy na VPS; crie registros DNS A/AAAA apontando para a VPS.
API_DOMAIN=apibig.fbr.news
# E-mail operacional usado pelo ACME para emitir e renovar certificados TLS automaticamente.
ACME_EMAIL=<operations-email-placeholder>

# URL do projeto Supabase; copie em Supabase Dashboard > Project Settings > API ou execute `supabase status` localmente.
SUPABASE_URL=http://127.0.0.1:54321
# Chave pública usada por clientes; copie a Publishable key em Supabase Dashboard > Project Settings > API.
SUPABASE_PUBLISHABLE_KEY=<publishable-key-placeholder>
# URL publica do Supabase embutida no bundle web; use a mesma Project URL acima, obtida no Connect/API settings. Nunca use URL administrativa.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Chave publica embutida no bundle web; copie somente a Publishable key do Supabase. Nunca use secret/service_role em NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable-key-placeholder>
# URL canônica cadastrada em Supabase Dashboard > Authentication > URL Configuration > Site URL; use APP_URL em produção.
SUPABASE_AUTH_SITE_URL=http://localhost:3000
# Redirects cadastrados no mesmo painel, separados por vírgula; inclua exatamente APP_URL/auth/callback.
SUPABASE_AUTH_REDIRECT_URLS=http://localhost:3000/auth/callback
# Confirmação não secreta de que Custom SMTP foi configurado e testado no Supabase Dashboard; produção falha ao iniciar se não for true.
SUPABASE_AUTH_SMTP_CONFIGURED=false
# Chave server-only com privilégios elevados; use a Secret key atual do Dashboard (ou a service_role legada, se aplicável) somente no secret manager da API/worker.
SUPABASE_SECRET_KEY=<service-role-placeholder>
# Somente CLI/migrations: identificador curto do projeto em Project Settings > General. Valor real apenas no .env/secret manager; nunca commitar.
SUPABASE_PROJECT_REF=<project-ref-placeholder>
# Somente CLI/migrations: Personal Access Token de Supabase Account > Access Tokens. Valor real apenas no .env/secret manager; nunca commitar.
SUPABASE_ACCESS_TOKEN=<access-token-placeholder>
# Somente CLI/migrations: senha do banco do projeto. Valor real apenas no .env/secret manager; nunca commitar ou expor ao frontend.
SUPABASE_DB_PASSWORD=<database-password-placeholder>
# DSN de aplicação com TLS, preferencialmente via pooler; copie em Supabase Dashboard > Connect > Transaction pooler e use `sslmode=require` (ou `verify-full`).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# DSN runtime separada para operacoes internas auditadas que nao podem inicializar via RLS; use um login dedicado de menor privilegio, distinto de DATABASE_URL, com TLS. Obtenha/provisione com a equipe de banco, nunca use o owner de migrations.
DATABASE_SERVICE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# DSN direto usado somente pelo job de migrations/admin, nunca pelos containers da API/worker; copie em Dashboard > Connect > Direct connection, restrinja a rede e use `sslmode=require` (ou `verify-full`).
DIRECT_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Nome do bucket privado de artefatos; crie/consulte em Supabase Dashboard > Storage ou pelas migrations do projeto.
STORAGE_BUCKET=artifacts
# Scanner ClamAV privado do compose de produção. Para scanner externo compatível, use URL HTTPS.
MALWARE_SCANNER_URL=clamd://clamav:3310
# Somente para scanner HTTP externo: credencial Bearer server-only. ClamAV interno nao usa chave.
MALWARE_SCANNER_API_KEY=

# DSN do Redis privado do compose. API e worker recebem este valor automaticamente em produção.
REDIS_URL=redis://:<redis-password>@redis:6379/0
# Senha forte do Redis privado criado por compose.production.yml; gere com `openssl rand -hex 32`. Redis nao publica porta no host.
REDIS_PASSWORD=<redis-password>
# Prefixo lógico da fila ARQ; definido pela equipe para isolar aplicação e ambiente no mesmo Redis.
QUEUE_NAME=bighead:jobs
# Duração, em segundos, do lease de um job antes de poder ser retomado; valor definido pela operação conforme o maior tempo normal de execução.
JOB_LEASE_SECONDS=300
# Override opcional: endpoint HTTPS server-to-server que executa um run. Vazio usa o router multi-LLM interno do worker.
RUN_PROVIDER_URL=
# Override opcional: credencial Bearer server-only do gateway acima. Deve ficar vazia quando RUN_PROVIDER_URL estiver vazia.
RUN_PROVIDER_API_KEY=
# Timeout maximo, em segundos, para uma chamada do executor; alinhe com a politica publicada das skills e com o lease do job.
RUN_PROVIDER_TIMEOUT_SECONDS=60

# Reserva para o Client ID do OAuth Google, ainda sem consumidor no código; crie em Google Cloud Console > APIs & Services > Credentials ao implementar o provider.
AUTH_GOOGLE_CLIENT_ID=
# Reserva para o Client secret do OAuth Google, ainda sem consumidor; copie do mesmo OAuth client e guarde no secret manager quando a integração for implementada.
AUTH_GOOGLE_CLIENT_SECRET=
# Reserva para o Client ID do OAuth Microsoft, ainda sem consumidor; crie em Microsoft Entra > App registrations ao implementar o provider.
AUTH_MICROSOFT_CLIENT_ID=
# Reserva para o Client secret do OAuth Microsoft, ainda sem consumidor; gere em Entra > Certificates & secrets somente ao integrar o provider.
AUTH_MICROSOFT_CLIENT_SECRET=
# Somente para Supabase self-hosted/provisionamento; no Cloud cadastre o host diretamente em Authentication > SMTP Settings.
SMTP_HOST=OPTIONAL_UNTIL_PROVIDER_SELECTED
# Somente para Supabase self-hosted/provisionamento; no Cloud não injete esta variável nos containers BigHead.
SMTP_PORT=587
# Somente para Supabase self-hosted/provisionamento; no Cloud guarde o usuário apenas no painel/secret manager do Supabase.
SMTP_USERNAME=OPTIONAL_UNTIL_PROVIDER_SELECTED
# Segredo exclusivo de Supabase self-hosted/provisionamento; nunca exponha ao web/API/worker. No Cloud salve apenas no painel Supabase.
SMTP_PASSWORD=OPTIONAL_UNTIL_PROVIDER_SELECTED

# Provedor LLM principal consumido pelo worker: openai, anthropic ou google.
LLM_PROVIDER_DEFAULT=
# Provedor LLM de contingencia; deve ser diferente do principal.
LLM_PROVIDER_FALLBACK=
# Nome exato do modelo principal no provedor selecionado.
LLM_MODEL_DEFAULT=
# Nome exato do modelo de fallback no provedor selecionado.
LLM_MODEL_FALLBACK=
# Timeout global do gateway multi-LLM; cada skill ainda pode impor limite menor.
LLM_TIMEOUT_SECONDS=60
# Reserva ainda sem consumidor para o modelo de embeddings; copie da documentação ao implementar e mantenha compatível com a dimensão do banco.
EMBEDDING_MODEL=OPTIONAL_UNTIL_PROVIDER_SELECTED
# Dimensão planejada do embedding, ainda sem adapter consumidor; confirme na documentação do modelo antes de indexar dados reais.
EMBEDDING_DIMENSION=1536
# Orçamento planejado de LLM em centavos, ainda sem adapter consumidor; defina com Produto/Finanças ao habilitar o provider.
LLM_MONTHLY_BUDGET_CENTS=500000
# Chave OpenAI server-only; obrigatoria apenas se OpenAI for principal ou fallback.
OPENAI_API_KEY=
# Chave Anthropic server-only; obrigatoria apenas se Anthropic for principal ou fallback.
ANTHROPIC_API_KEY=
# Chave Google Gen AI server-only; obrigatoria apenas se Google for principal ou fallback.
GOOGLE_GENAI_API_KEY=

# Integracao opcional com CRM externo. O CRM interno BigHead funciona sem esta variavel. Para sincronizar um provedor externo, use mapa JSON provider->origem HTTPS allowlisted, por exemplo {"hubspot":"https://api.hubapi.com"}.
CRM_PROVIDER_ENDPOINTS={}
# Reserva ainda sem consumidor para enriquecimento; gere no fornecedor homologado somente ao implementar o adapter.
ENRICHMENT_API_KEY=OPTIONAL_UNTIL_PROVIDER_SELECTED
# Reserva ainda sem consumidor para campanhas de e-mail; gere no fornecedor somente ao implementar o adapter.
EMAIL_PROVIDER_API_KEY=OPTIONAL_UNTIL_PROVIDER_SELECTED
# Reserva ainda sem consumidor para publicação social; obtenha no app OAuth/API somente ao implementar o adapter.
SOCIAL_PUBLISHING_API_KEY=OPTIONAL_UNTIL_PROVIDER_SELECTED
# Reserva carregada pela API, mas sem wiring operacional global comprovado; gere com `openssl rand -hex 32` ao definir a estratégia de assinatura e guarde no secret manager.
WEBHOOK_SIGNING_SECRET=<webhook-secret-placeholder>

# DSN opcional de captura de erros da API e worker; copie em Sentry > Project Settings > Client Keys, ou deixe vazio para desativar.
SENTRY_DSN=
# Endpoint opcional OTLP/HTTP usado pela API e worker; deixe vazio no lançamento para operar somente com logs estruturados.
OTEL_EXPORTER_OTLP_ENDPOINT=
# Headers de autenticação OTLP no formato `chave=valor`; copie do provedor APM ou deixe vazio para o collector local.
OTEL_EXPORTER_OTLP_HEADERS=
# Nome lógico usado para identificar os serviços nos traces; definido pela equipe e diferenciado por aplicação/ambiente quando necessário.
OTEL_SERVICE_NAME=bighead-platform

# Reserva carregada pela config, sem uso criptográfico comprovado; gere 32+ caracteres com CSPRNG quando o fluxo for implementado e guarde no secret manager.
ENCRYPTION_KEY=<32-char-placeholder>
# Pepper secreto aplicado aos tokens do portal; gere com CSPRNG, por exemplo `openssl rand -hex 32`, e nunca persista junto aos hashes.
PORTAL_TOKEN_PEPPER=<portal-pepper-placeholder>
# Validade do download assinado em segundos; defina pela política de segurança. Uploads assinados do Supabase permanecem fixos em duas horas.
SIGNED_URL_TTL_SECONDS=900
